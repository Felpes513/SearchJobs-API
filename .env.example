# Database (localhost para rodar local, ignorado pelo docker-compose)
DB_URL=jdbc:postgresql://localhost:5432/searchjobs
DB_USERNAME=postgres
DB_PASSWORD=your_password_here

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRATION_ACCESS=900000
JWT_EXPIRATION_REFRESH=604800000

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Storage
STORAGE_RESUMES_DIR=uploads/resumes

# JSearch (RapidAPI)
JSEARCH_API_KEY=your_jsearch_api_key_here
JSEARCH_API_HOST=jsearch.p.rapidapi.com
JSEARCH_BASE_URL=https://jsearch.p.rapidapi.com

# GitHub (opcional - aumenta o rate limit da API publica)
GITHUB_TOKEN=